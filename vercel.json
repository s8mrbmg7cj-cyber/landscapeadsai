{
  "version": 2,
  "builds": [
    { "src": "api/generate.js", "use": "@vercel/node" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/stripe-config", "dest": "/api/generate.js" },
    { "src": "/api/create-checkout", "dest": "/api/generate.js" },
    { "src": "/api/generate", "dest": "/api/generate.js" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ]
}
